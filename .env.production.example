# =============================================================================
# Piperly — LIVE / PRODUCTION
# =============================================================================
#
# Recommended stack (what we use for this project):
#   • VPS: Hetzner CPX21 or DigitalOcean 2GB + Laravel Forge
#   • Web: Nginx → public/  |  PHP 8.3 + ext-intl, redis, bcmath
#   • Database: MySQL 8 on same server (or managed DB)
#   • Cache / queues / sessions: Redis + Horizon
#   • Email: Postmark (transactional — trials, invoices, invites)
#   • Payments: Stripe Live
#   • Domain: piperly.com (HTTPS via Forge / Let's Encrypt)
#
# On server after copying to `.env`:
#   php artisan key:generate --force
#   php artisan migrate --force && php artisan db:seed --force
#   php artisan platform:ensure-owner && php artisan platform:apply-branding
#   php artisan storage:link
#   php artisan config:cache && php artisan route:cache && php artisan view:cache
#
# Stripe webhook URL (Live mode):
#   https://piperly.com/payments-providers/stripe/webhook
#
# Paste your Stripe Live keys + Postmark token from each provider dashboard
# (only external secrets — everything else below is ready to use).
# =============================================================================

APP_NAME=Piperly
APP_DESCRIPTION="Piperly is the multi-tenant CRM for leads, deals, contacts, and sales follow-ups."
APP_ENV=production
APP_KEY=base64:EcjAm1p7YpnFjru2lEGYxXoisoiBAQiWnw6csnOULxE=
APP_DEBUG=false
APP_URL=https://piperly.com
APP_TIMEZONE=UTC

VITE_USE_DEV_SERVER=false

PLATFORM_OWNER_EMAIL=owner@piperly.com
