# Laragon / native PHP (no Docker) — copy to .env and adjust
# See docs/local-development.md

APP_NAME=Piperly
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

VITE_USE_DEV_SERVER=false

PLATFORM_OWNER_EMAIL=owner@piperly.test
PLATFORM_OWNER_PASSWORD=ChangeMe-Platform-2026!
PLATFORM_OWNER_NAME="Platform Owner"
PLATFORM_SUPPORT_EMAIL=support@piperly.test

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=piperly
DB_USERNAME=root
DB_PASSWORD=

# Use database queue on Laragon unless you run Redis locally (Memurai / WSL).
# With Redis: QUEUE_CONNECTION=redis, CACHE_DRIVER=redis, REDIS_HOST=127.0.0.1
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=4320

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_LEVEL=debug
DEBUGBAR_ENABLED=true

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=

TRIAL_WITHOUT_PAYMENT_ENABLED=true
TRIAL_WITHOUT_PAYMENT_MINIMAL_SIGNUP=true
TRIAL_WITHOUT_PAYMENT_SMS_VERIFICATION_ENABLED=false
TRIAL_WITHOUT_PAYMENT_FIRST_REMINDER_ENABLED=true
TRIAL_WITHOUT_PAYMENT_FIRST_REMINDER_DAYS=3
TRIAL_WITHOUT_PAYMENT_SECOND_REMINDER_ENABLED=true
TRIAL_WITHOUT_PAYMENT_SECOND_REMINDER_DAYS=1
LIMIT_USER_TRIALS_ENABLED=true
LIMIT_USER_TRIALS_MAX_COUNT=1
OTP_LOGIN_ENABLED=false
ADMIN_SETTINGS_ENABLED=true
