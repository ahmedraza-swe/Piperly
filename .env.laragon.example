# Laragon / native PHP (no Docker) — copy to .env and adjust
# See docs/local-development.md

APP_NAME=CRMercy
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

VITE_USE_DEV_SERVER=false

PLATFORM_OWNER_EMAIL=owner@crmercy.test
PLATFORM_OWNER_PASSWORD=ChangeMe-Platform-2026!
PLATFORM_OWNER_NAME="Platform Owner"

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crmercy
DB_USERNAME=root
DB_PASSWORD=

# Use database queue on Laragon unless you run Redis locally (Memurai / WSL).
# With Redis: QUEUE_CONNECTION=redis, CACHE_DRIVER=redis, REDIS_HOST=127.0.0.1
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=4320

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_LEVEL=debug
DEBUGBAR_ENABLED=true
