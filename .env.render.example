# =============================================================================
# Piperly on Render.com — paste into Environment (no paid Shell required)
# =============================================================================
# MySQL: use Railway free tier → New Project → MySQL → copy credentials below
# After saving env vars: Deploy latest commit (migrations + seed run automatically)
# =============================================================================

APP_NAME=Piperly
APP_DESCRIPTION="Piperly is the multi-tenant CRM for leads, deals, contacts, and sales follow-ups."
APP_ENV=production
APP_KEY=base64:EcjAm1p7YpnFjru2lEGYxXoisoiBAQiWnw6csnOULxE=
APP_DEBUG=false
APP_URL=https://YOUR_RENDER_URL.onrender.com
APP_TIMEZONE=UTC
VITE_USE_DEV_SERVER=false

PLATFORM_OWNER_EMAIL=owner@piperly.com
PLATFORM_OWNER_PASSWORD=Piperly-Owner-2026!Secure#Admin
PLATFORM_OWNER_NAME=Platform Owner
PLATFORM_SUPPORT_EMAIL=support@piperly.com
PLATFORM_DEFAULT_TRIAL_PLAN_SLUG=starter-monthly

LOG_CHANNEL=stderr
LOG_LEVEL=warning
DEBUGBAR_ENABLED=false
TELESCOPE_ENABLED=false

# External MySQL (Railway / PlanetScale / Aiven) — REQUIRED
DB_CONNECTION=mysql
DB_HOST=your-mysql-host.railway.app
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=your-mysql-password

# No Redis on Render free tier — use file/database instead
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
SESSION_LIFETIME=4320
SESSION_SECURE_COOKIE=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@piperly.com
MAIL_FROM_NAME=Piperly

TRIAL_WITHOUT_PAYMENT_ENABLED=true
TRIAL_WITHOUT_PAYMENT_MINIMAL_SIGNUP=true
LIMIT_USER_TRIALS_ENABLED=true
LIMIT_USER_TRIALS_MAX_COUNT=1
ADMIN_SETTINGS_ENABLED=true
OTP_LOGIN_ENABLED=false

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
