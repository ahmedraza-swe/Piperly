# =============================================================================
# Piperly on Render.com — paste into Environment (RAW / bulk)
# =============================================================================
# IMPORTANT:
# - Local .env does NOT affect Render
# - Render has NO MySQL and NO Redis
# - ${{MySQL.*}} syntax ONLY works on Railway — NOT on Render
# - Copy PUBLIC MySQL host from Railway MySQL → Connect → Public Network
# =============================================================================

APP_NAME=Piperly
APP_DESCRIPTION="Piperly is the multi-tenant CRM for leads, deals, contacts, and sales follow-ups."
APP_ENV=production
APP_KEY=base64:EcjAm1p7YpnFjru2lEGYxXoisoiBAQiWnw6csnOULxE=
APP_DEBUG=false
APP_URL=https://piperly.onrender.com
APP_TIMEZONE=UTC
VITE_USE_DEV_SERVER=false

PLATFORM_OWNER_EMAIL=owner@piperly.com
PLATFORM_OWNER_PASSWORD=Piperly-Owner-2026!Secure#Admin
PLATFORM_OWNER_NAME=Platform Owner
PLATFORM_SUPPORT_EMAIL=support@piperly.com
PLATFORM_DEFAULT_TRIAL_PLAN_SLUG=starter-monthly

LOG_CHANNEL=stderr
LOG_LEVEL=warning
DEBUGBAR_ENABLED=false
TELESCOPE_ENABLED=false

# --- MySQL (Railway public credentials — NOT 127.0.0.1) ---
DB_CONNECTION=mysql
DB_HOST=REPLACE_WITH_RAILWAY_PUBLIC_HOST
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=REPLACE_WITH_RAILWAY_PASSWORD

# --- No Redis on Render free tier ---
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
SESSION_LIFETIME=4320
SESSION_SECURE_COOKIE=true
# Do NOT set SESSION_DOMAIN on *.onrender.com

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@piperly.com
MAIL_FROM_NAME=Piperly

TRIAL_WITHOUT_PAYMENT_ENABLED=true
TRIAL_WITHOUT_PAYMENT_MINIMAL_SIGNUP=true
LIMIT_USER_TRIALS_ENABLED=true
LIMIT_USER_TRIALS_MAX_COUNT=1
ADMIN_SETTINGS_ENABLED=true
OTP_LOGIN_ENABLED=false
COOKIE_CONSENT_ENABLED=false
SITEMAP_AUTO_GENERATION_ENABLED=false

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
