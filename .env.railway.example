# =============================================================================
# Piperly on Railway — reference variables (set in Railway Dashboard)
# =============================================================================
# Setup: docs/railway-deploy.md
# MySQL plugin auto-injects MYSQL* vars — entrypoint maps them to Laravel DB_*
# =============================================================================

APP_NAME=Piperly
APP_ENV=production
APP_KEY=base64:EcjAm1p7YpnFjru2lEGYxXoisoiBAQiWnw6csnOULxE=
APP_DEBUG=false
APP_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
APP_TIMEZONE=UTC
VITE_USE_DEV_SERVER=false

PLATFORM_OWNER_EMAIL=owner@piperly.com
PLATFORM_OWNER_PASSWORD=Piperly-Owner-2026!Secure#Admin
PLATFORM_OWNER_NAME=Platform Owner
PLATFORM_SUPPORT_EMAIL=support@piperly.com
PLATFORM_DEFAULT_TRIAL_PLAN_SLUG=starter-monthly

LOG_CHANNEL=stderr
LOG_LEVEL=warning
DEBUGBAR_ENABLED=false
TELESCOPE_ENABLED=false

DB_CONNECTION=mysql

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
SESSION_LIFETIME=4320
SESSION_SECURE_COOKIE=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@piperly.com
MAIL_FROM_NAME=Piperly

TRIAL_WITHOUT_PAYMENT_ENABLED=true
TRIAL_WITHOUT_PAYMENT_MINIMAL_SIGNUP=true
LIMIT_USER_TRIALS_ENABLED=true
LIMIT_USER_TRIALS_MAX_COUNT=1
ADMIN_SETTINGS_ENABLED=true
OTP_LOGIN_ENABLED=false

STRIPE_SECRET_KEY=
